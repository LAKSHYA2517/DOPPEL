{
  "name": "twin-agent",
  "version": "1.0.0",
  "scripts": {
    "dev": "concurrently \"cd backend && python -m uvicorn main:app --reload\" \"cd frontend && npm run dev\"",
    "dev:backend": "cd backend && python -m uvicorn main:app --reload",
    "dev:frontend": "cd frontend && npm run dev"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}